{
  "name": "ai-commit",
  "displayName": "AI Commit",
  "description": "Use Azure/OpenAI API to review Git changes, generate conventional commit messages that meet the conventions, simplify the commit process, and keep the commit conventions consistent.",
  "version": "0.1.1",
  "engines": {
    "node": ">=16",
    "vscode": "^1.77.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Azure",
    "OpenAI",
    "ChatGPT",
    "GitEmoji",
    "Git Commit",
    "Conventional Commits",
    "Commitizen",
    "Commit Message",
    "Commit Message Generator",
    "AI Commit",
    "Auto Commit"
  ],
  "publisher": "sitoi",
  "repository": "https://github.com/sitoi/ai-commit",
  "icon": "images/logo.png",
  "activationEvents": [
    "onCommand:ai-commit"
  ],
  "contributes": {
    "commands": [
      {
        "command": "extension.ai-commit",
        "icon": {
          "dark": "images/icon.svg",
          "light": "images/icon.svg"
        },
        "title": "AI Commit"
      }
    ],
    "configuration": {
      "properties": {
        "ai-commit.AI_COMMIT_LANGUAGE": {
          "default": "English",
          "description": "Commit message language",
          "enum": [
            "Simplified Chinese",
            "Traditional Chinese",
            "Japanese",
            "Korean",
            "Czech",
            "German",
            "French",
            "Italian",
            "Dutch",
            "Portuguese",
            "Vietnamese",
            "English",
            "Spanish",
            "Swedish",
            "Russian",
            "Bahasa",
            "Polish",
            "Turkish",
            "Thai"
          ],
          "enumDescriptions": [
            "简体中文",
            "繁體中文",
            "にほんご",
            "한국어",
            "česky",
            "Deutsch",
            "française",
            "italiano",
            "Nederlands",
            "português",
            "tiếng Việt",
            "english",
            "español",
            "Svenska",
            "русский",
            "bahasa",
            "Polski",
            "Turkish",
            "ไทย"
          ],
          "type": "string"
        },
        "ai-commit.AI_COMMIT_SYSTEM_PROMPT": {
          "type": "string",
          "default": "",
          "description": "Custom system prompt for generating commit messages"
        },
        "ai-commit.servers": {
          "type": "array",
          "default": [],
          "description": "AI server configurations. Each entry defines a provider with its API credentials and available models. Servers are tried in order; on failure the next server is used automatically.",
          "items": {
            "type": "object",
            "required": [
              "type",
              "apiKey",
              "models"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "openai",
                  "gemini",
                  "azure"
                ],
                "description": "Provider type"
              },
              "baseURL": {
                "type": "string",
                "description": "API base URL (required for openai/azure, optional for gemini)"
              },
              "apiKey": {
                "type": "string",
                "description": "API key for the provider"
              },
              "apiVersion": {
                "type": "string",
                "description": "Azure API version (azure only)"
              },
              "timeout": {
                "type": "number",
                "description": "Per-server timeout in ms (overrides global timeout)"
              },
              "models": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Model name"
                    },
                    "temperature": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 2,
                      "description": "Per-model temperature (overrides global temperature)"
                    },
                    "maxTokens": {
                      "type": "number",
                      "minimum": 0,
                      "default": 0,
                      "description": "Per-model max output tokens (0 = no limit, overrides global maxTokens)"
                    },
                    "reasoningEffort": {
                      "type": "string",
                      "enum": [
                        "none",
                        "low",
                        "medium",
                        "high"
                      ],
                      "description": "For OpenAI reasoning models (o1/o3): controls reasoning effort. 'none' = no reasoning tokens."
                    },
                    "options": {
                      "type": "object",
                      "description": "Provider-specific options as key-value pairs. Any additional parameters not covered by the schema can be passed through here."
                    }
                  }
                },
                "description": "List of models available on this server"
              }
            }
          }
        },
        "ai-commit.timeout": {
          "type": "number",
          "default": 60000,
          "minimum": 1000,
          "description": "Global default timeout in ms. Used when a server does not specify its own timeout."
        },
        "ai-commit.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Global default temperature (0-2). Used when a model does not specify its own temperature."
        },
        "ai-commit.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Global default max output tokens (0 = no limit). Used when a model does not specify its own."
        },
        "ai-commit.reasoningEffort": {
          "type": "string",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "none",
          "description": "Global default reasoning effort for OpenAI reasoning models (o1/o3). 'none' = no reasoning tokens."
        },
        "ai-commit.USE_GITMOJI": {
          "type": "boolean",
          "default": true,
          "description": "Whether to use gitmoji in commit messages. When true, uses prompt/with_gitmoji.md; when false, uses prompt/without_gitmoji.md."
        }
      },
      "title": "AI Commit"
    },
    "menus": {
      "scm/title": [
        {
          "command": "extension.ai-commit",
          "group": "navigation"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsdown --minify",
    "compile": "tsdown",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "publish": "vsce publish --no-dependencies",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "npm run build",
    "watch": "tsdown --watch",
    "watch-tests": "tsc -p . -w --outDir out"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.77.0",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "@vscode/test-electron": "^2.3.0",
    "eslint": "^8.36.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "fs-extra": "^11.0.4",
    "openai": "^6.33.0",
    "simple-git": "^3.17.0"
  },
  "resolutions": {
    "@types/node": "16.x"
  },
  "license": "MIT"
}
